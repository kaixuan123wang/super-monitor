{
  "name": "@wonderful-world/sdk",
  "version": "1.0.0",
  "description": "JS Monitor SDK - 前端错误/性能/埋点监控",
  "main": "build/sdk.umd.js",
  "module": "build/sdk.esm.js",
  "browser": "build/sdk.iife.js",
  "types": "build/index.d.ts",
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "clean": "rimraf build",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "monitor",
    "sdk",
    "error-tracking",
    "tracking",
    "performance"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.0.2",
    "rimraf": "^5.0.5",
    "rollup": "^4.9.6",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "glob": ">=10.5.0",
      "serialize-javascript": ">=7.0.5"
    }
  }
}
